# Google OAuth (required for authentication)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Calendar redirect URI (update for production)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/calendar/callback

# Email notifications
# Option 1: Azure Communication Services (default)
EMAIL_PROVIDER=azure
AZURE_COMM_CONNECTION_STRING=endpoint=https://your-resource.communication.azure.com/;accesskey=your-access-key
AZURE_EMAIL_SENDER=DoNotReply@your-verified-domain.azurecomm.net

# Option 2: SMTP (Gmail with app password)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-gmail-app-password

# Note for Azure: Ensure your sender domain is verified and MailFrom address is configured
# in Azure Communication Services > Email > Provision Domains

# Internal API secret (change for production)
INTERNAL_SECRET=generate-a-random-secret-here

# Environment
NODE_ENV=development

# Port (Railway sets this automatically)
PORT=3000

# API base URL (for scheduler to call internal endpoints)
API_BASE_URL=http://localhost:3000
